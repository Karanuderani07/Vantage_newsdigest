# Required API Keys
GROQ_API_KEY="your_groq_api_key_here"
NEWS_API_KEY="your_newsapi_key_here"

# Email (optional — for digest emails)
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here   # Use App Password for Gmail, not your actual password
SMTP_HOST=smtp.gmail.com                # default
SMTP_PORT=465                           # default
FROM_NAME=News Digest Agent             # optional display name